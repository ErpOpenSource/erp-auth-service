# --- Postgres credentials (same as infra repo) ---
POSTGRES_USER=erp_admin
POSTGRES_PASSWORD=admin1234

# --- Auth JWT / Refresh ---
# Minimum recommended for HS256: 32+ bytes
AUTH_JWT_SECRET=change-this-super-secret-key-very-long-32-bytes-min
AUTH_JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
AUTH_REFRESH_EXPIRATION_DAYS_DEFAULT=7
AUTH_REFRESH_EXPIRATION_DAYS_REMEMBER_ME=30
AUTH_REFRESH_PEPPER=change-me-pepper
